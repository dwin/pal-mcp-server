{
  "name": "codex",
  "command": "codex",
  "additional_args": [
    "--json",
    "--dangerously-bypass-approvals-and-sandbox",
    "--enable",
    "web_search_request"
  ],
  "model_config": {
    "flag": "-m",
    "default": "gpt-5.3-codex",
    "models": ["gpt-5.3-codex", "gpt-5.3-codex-spark", "gpt-5.2-codex", "gpt-5.2", "gpt-5.1-codex-max", "gpt-5.1-codex-mini"]
  },
  "env": {},
  "roles": {
    "default": {
      "prompt_path": "systemprompts/clink/default.txt",
      "role_args": []
    },
    "planner": {
      "prompt_path": "systemprompts/clink/default_planner.txt",
      "role_args": []
    },
    "codereviewer": {
      "prompt_path": "systemprompts/clink/codex_codereviewer.txt",
      "role_args": []
    },
    "analyze": {
      "prompt_path": "systemprompts/clink/default_analyze.txt",
      "role_args": []
    },
    "secaudit": {
      "prompt_path": "systemprompts/clink/default_secaudit.txt",
      "role_args": []
    },
    "tracer": {
      "prompt_path": "systemprompts/clink/default_tracer.txt",
      "role_args": []
    },
    "docgen": {
      "prompt_path": "systemprompts/clink/default_docgen.txt",
      "role_args": []
    }
  }
}